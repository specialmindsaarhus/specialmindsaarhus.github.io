---
import '../styles/global.css';

interface Props {
	title: string;
	showNav?: boolean;
}

const { title, showNav = true } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen">
		<header class={`site-header${!showNav ? ' site-header--logo-only' : ''}`}>
			<a href="/">
				<img src="/special-minds-logo.png" alt="Special Minds" class="site-logo" />
			</a>
		</header>
		<slot />
		<footer class="site-footer">
			<div class="site-footer__logo">
				<img src="/special-minds-logo.png" alt="Special Minds" class="site-logo" />
			</div>
			<div class="site-footer__inner">
				<div class="site-footer__col site-footer__col--left">
					<h3>Special Minds er</h3>
					<p>en socialøkonomisk virksomhed som gennem uddannelses- og beskæftigelsesrettede indsatser hjælper unge og voksne med Autisme Spektrum Forstyrrelse til at lykkes med uddannelse eller job.</p>
				</div>
				<div class="site-footer__divider"></div>
				<div class="site-footer__col site-footer__col--right">
					<h3>Special Minds bor</h3>
					<address>
						Gunnar Clausens Vej 68<br />
						8260 Viby J<br />
						Telefon: 86 12 56 60<br />
						E-mail: <a href="mailto:kontakt@specialminds.dk">kontakt@specialminds.dk</a>
					</address>
				</div>
			</div>
		</footer>
	</body>
</html>
