---
interface Props {
	title: string;
	body: string;
	href: string;
	image?: string;
}

const { href, title, body, image } = Astro.props;
---

<li class="link-card">
	<a href={href}>
		{image && <img src={image} alt="" style="max-width: 100%; aspect-ratio: 5/1; object-fit: cover;" />}
		<div style="padding: 1.2rem;">
			<h2>
				{title}
				<span>&rarr;</span>
			</h2>
			<p>
				{body}
			</p>
		</div>
	</a>
</li>
<style>
	h2 {
		margin: 0;
		font-weight: 600;
		font-size: 1.5rem;
		text-align: left;
		transition: color 0.6s cubic-bezier(0.22, 1, 0.36, 1);
	}
	p {
		margin-top: 0.75rem;
		margin-bottom: 0;
		font-size: 1rem;
		text-align: left;
	}
</style>
