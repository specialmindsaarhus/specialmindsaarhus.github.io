---
interface Props {
	title: string;
	body: string;
	href: string;
	image?: string;
}

const { href, title, body, image } = Astro.props;
---

<li class="link-card">
	<a href={href}>
		{image
			? <img src={image} alt="" class="card-img" />
			: <div class="card-img card-placeholder"></div>
		}
		<div class="card-body">
			<h2>{title}</h2>
			<p>{body}</p>
		</div>
	</a>
</li>
<style>
	.card-img {
		width: 100%;
		aspect-ratio: 16 / 7;
		object-fit: cover;
		display: block;
	}
	.card-placeholder {
		background: #4ba59d;
		opacity: 0.35;
	}
	.card-body {
		/*padding: 1.1rem 1.2rem 1.2rem;*/
		display: flex;
		flex-direction: column;
		justify-content: space-between;	
	}
	h2 {
		margin: 0;
		font-weight: 400;
		font-size: 1.2rem;
		text-align: left;
		transition: color 0.6s cubic-bezier(0.22, 1, 0.36, 1);
	}
	p {
		margin-top: 0.6rem;
		margin-bottom: 0;
		font-size: 0.8rem;
		text-align: left;
		border-left: 2px solid rgba(255, 255, 255, 0.22);
		padding-left: 0.65rem;
		color: rgb(255 255 255 / 62%);
	}
</style>
